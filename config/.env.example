# Medical Diagnosis Agent — Required Environment Variables
# Copy this file to .env and fill in your values

# ── LLM API Keys ────────────────────────────────────────────────
# Primary: Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# Fallback: OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Offline/Privacy mode: Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Privacy Mode ─────────────────────────────────────────────────
# Set PRIVACY_MODE=true to force all LLM calls through local Ollama.
# Use this when handling real patient data (PHI) to avoid cloud API exposure.
PRIVACY_MODE=false

# ── HuggingFace ──────────────────────────────────────────────────
# Required if downloading gated models from HuggingFace Hub
HF_TOKEN=your_huggingface_token_here

# ── Agent Configuration ──────────────────────────────────────────
DATA_DIR=./data
MODELS_DIR=./models
HOST=0.0.0.0
PORT=8008
LOG_LEVEL=INFO

# ── PubMed API (NCBI Entrez) ─────────────────────────────────────
# Optional: include your email for higher rate limits (3 req/s vs 3/s unauthenticated)
NCBI_EMAIL=your_email@example.com
# Optional NCBI API key for 10 req/s rate limit
NCBI_API_KEY=

# ── SECURITY NOTE ────────────────────────────────────────────────
# This agent handles health-related queries. All outputs include safety disclaimers.
# NEVER deploy this agent as a replacement for professional medical care.
# ALWAYS set PRIVACY_MODE=true when handling any real patient information (PHI/PII).
